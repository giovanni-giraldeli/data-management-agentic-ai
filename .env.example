# =============================================================================
# Agentic AI Data Management – Environment Configuration
# Copy this file to .env and fill in the values for your environment.
# =============================================================================

# -----------------------------------------------------------------------------
# LLM Provider (required)
# -----------------------------------------------------------------------------
# Set LLM_MODEL to any model supported by your installed LangChain provider
# package.  Examples:
#
#   Provider              | LLM_MODEL value                                | Package to install         | Cost
#   ----------------------|------------------------------------------------|----------------------------|-------------------------------
#   Google GenAI ★        | google_genai/gemini-2.5-flash                  | langchain-google-genai     | Free tier (AI Studio)
#   Google GenAI          | google_genai/gemini-2.0-flash                  | langchain-google-genai     | Free tier (AI Studio)
#   Anthropic             | anthropic/claude-3-5-sonnet-20241022           | langchain-anthropic        | Requires API credits
#   Anthropic             | anthropic/claude-3-5-haiku-20241022            | langchain-anthropic        | Requires API credits
#   OpenAI                | openai/gpt-4o                                  | langchain-openai           | Requires API credits
#   OpenAI                | openai/gpt-4o-mini                             | langchain-openai           | Requires API credits
#   Ollama (local)        | ollama/llama3.1                                | langchain-ollama           | Free, runs locally
#   OpenRouter (any)      | openai/google/gemini-2.5-flash                 | langchain-openai           | Paid per token
#   OpenRouter (free) ★   | openai/google/gemini-2.0-flash-exp:free        | langchain-openai           | Free tier (OpenRouter)
#   OpenRouter (free)     | openai/meta-llama/llama-3.3-70b-instruct:free  | langchain-openai           | Free tier (OpenRouter)
#
# --- Direct providers ---
# Recommended: Google Gemini 2.5 Flash via AI Studio (free tier)
#   1. Get a free API key at https://aistudio.google.com
#   2. uv pip install langchain-google-genai
#   3. Set GOOGLE_API_KEY below
#
# --- OpenRouter (access any model via one API key) ---
# OpenRouter exposes an OpenAI-compatible API, so use the 'openai' LangChain
# provider and point it at OpenRouter's endpoint.  The LLM_MODEL format is
# openai/<openrouter-model-name>, e.g. openai/google/gemini-2.5-flash.
#   1. Get an API key at https://openrouter.ai
#   2. uv pip install langchain-openai
#   3. Set OPENAI_API_KEY and OPENAI_BASE_URL below
#
LLM_MODEL=google_genai/gemini-2.5-flash
LLM_TEMPERATURE=0
# Maximum tokens per LLM response. Keeps OpenRouter from reserving the model's
# full context window against your credit balance. 4096 is enough for this
# system; set to 0 to use the provider default (not recommended for OpenRouter).
LLM_MAX_TOKENS=4096
# Rate limit for LLM API calls (requests per minute), shared across all agents.
# Set this to the limit of your API tier to avoid 429 errors.
# The pipeline queues requests proactively so the API never sees a burst.
#   Gemini AI Studio free tier : LLM_RPM_LIMIT=15
#   Gemini AI Studio paid tier : LLM_RPM_LIMIT=2000
#   OpenRouter free models     : LLM_RPM_LIMIT=20
#   0 = unlimited (default)
LLM_RPM_LIMIT=0

# Direct provider keys (uncomment the one you use):
GOOGLE_API_KEY=AIza...
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# OpenRouter — uncomment and fill in to use any model via OpenRouter:
# OPENAI_API_KEY=sk-or-...
# OPENAI_BASE_URL=https://openrouter.ai/api/v1

# -----------------------------------------------------------------------------
# DuckDB
# -----------------------------------------------------------------------------
# Absolute or relative path to the DuckDB warehouse file.
# The data directory is gitignored; load source CSVs before running the pipeline.
DUCKDB_PATH=data/warehouse.duckdb

# -----------------------------------------------------------------------------
# dbt
# -----------------------------------------------------------------------------
DBT_PROJECT_DIR=agentic_dbt_project
DBT_PROFILES_DIR=profiles

# -----------------------------------------------------------------------------
# Audit trail
# -----------------------------------------------------------------------------
AUDIT_LOG_PATH=audit_trail.jsonl

# -----------------------------------------------------------------------------
# Optional: override the default pipeline task
# -----------------------------------------------------------------------------
# PIPELINE_TASK=Analyse the data warehouse and build the analytical layer.

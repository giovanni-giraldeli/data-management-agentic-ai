# =============================================================================
# Agentic AI Data Management – Environment Configuration
# Copy this file to .env and fill in the values for your environment.
# =============================================================================

# -----------------------------------------------------------------------------
# LLM Provider (required)
# -----------------------------------------------------------------------------
# Set LLM_MODEL to any model supported by your installed LangChain provider
# package.  Examples:
#
#   Provider            | LLM_MODEL value                                  | Package to install         | Cost
#   --------------------|--------------------------------------------------|----------------------------|---------------------------
#   Google GenAI ★ free | google_genai/gemini-2.5-flash                    | langchain-google-genai     | Free tier (AI Studio)
#   Google GenAI        | google_genai/gemini-2.0-flash                    | langchain-google-genai     | Free tier (AI Studio)
#   Google GenAI        | google_genai/gemini-1.5-pro                      | langchain-google-genai     | Free tier (AI Studio)
#   Anthropic           | anthropic/claude-3-5-sonnet-20241022             | langchain-anthropic        | Requires API credits
#   Anthropic           | anthropic/claude-3-5-haiku-20241022              | langchain-anthropic        | Requires API credits
#   OpenAI              | openai/gpt-4o                                    | langchain-openai           | Requires API credits
#   OpenAI              | openai/gpt-4o-mini                               | langchain-openai           | Requires API credits
#   Ollama (local)      | ollama/llama3.1                                  | langchain-ollama           | Free, runs locally
#
# Recommended zero-cost option: Google Gemini 2.5 Flash (free tier)
#   Best cost-benefit model for agentic pipelines: strong tool use, structured output, and reasoning.
#   1. Get a free API key at https://aistudio.google.com
#   2. uv pip install langchain-google-genai
#   3. Set GOOGLE_API_KEY below
#
LLM_MODEL=google_genai/gemini-2.5-flash
LLM_TEMPERATURE=0

# API key for your chosen provider (only one is needed):
GOOGLE_API_KEY=AIza...
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# -----------------------------------------------------------------------------
# DuckDB
# -----------------------------------------------------------------------------
# Absolute or relative path to the DuckDB warehouse file.
# The data directory is gitignored; load source CSVs before running the pipeline.
DUCKDB_PATH=data/warehouse.duckdb

# -----------------------------------------------------------------------------
# dbt
# -----------------------------------------------------------------------------
DBT_PROJECT_DIR=agentic_dbt_project
DBT_PROFILES_DIR=profiles

# -----------------------------------------------------------------------------
# Audit trail
# -----------------------------------------------------------------------------
AUDIT_LOG_PATH=audit_trail.jsonl

# -----------------------------------------------------------------------------
# Optional: override the default pipeline task
# -----------------------------------------------------------------------------
# PIPELINE_TASK=Analyse the data warehouse and build the analytical layer.
